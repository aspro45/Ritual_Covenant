# Copy this file to .env and fill it locally.
# Never paste the private key in chat, Discord, GitHub, screenshots, or tickets.
# Use a burner wallet with only the testnet funds you want to spend.

RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_CHAIN_ID=1979

# Private key of the burner deployer wallet.
# Must start with 0x and be 64 hex chars after 0x.
DEPLOYER_PRIVATE_KEY=0xYOUR_BURNER_PRIVATE_KEY_HERE
# Optional. If empty, deployer address becomes the initial attestor.
INITIAL_ATTESTOR=

# Optional smoke registration values used after deploy.
# Keep AGENT_BOND small while testing with limited faucet funds.
RUN_DEPLOY_SMOKE_TEST=false
AGENT_ADDRESS=
SUCCESSOR_ADDRESS=
POLICY_HASH=
POLICY_CID=ipfs://ritual-covenant-policy-demo
MEMORY_CID=ipfs://ritual-covenant-memory-demo
AGENT_BOND=0.05

# Optional values used by npm.cmd run contract:live.
EXECUTION_VALUE=0.005
AGENT_GAS_TARGET=0.03
AGENT_GAS_MINIMUM=0.015

# Optional values used by npm.cmd run contract:deploy:guardian.
# Run with DRY_RUN=true first to estimate gas without spending testnet funds.
DRY_RUN=true
COVENANT_KERNEL_ADDRESS=0x4086710799f9d1Cb1eDb4D0a64522F00A5790270
GUARDIAN_PURPOSE_CID=ipfs://ritual-covenant/guardian-purpose
GUARDIAN_PURPOSE_HASH=
GUARDIAN_MAX_INTENT_VALUE=0.01
GUARDIAN_REQUIRE_TARGET_ALLOWLIST=true
DEPLOY_RESERVE=0.01

# Optional values used by npm.cmd run contract:deploy:bounty.
BOUNTY_DEPLOY_RESERVE=0.005

# Optional values used by npm.cmd run contract:guardian:live.
GUARDIAN_BOND=0.02
GUARDIAN_EXECUTION_VALUE=0.001
GUARDIAN_POLICY_CID=ipfs://ritual-covenant/guardian-live-policy
GUARDIAN_POLICY_HASH=
GUARDIAN_MISSION_CID=ipfs://ritual-covenant/guardian-live-mission
